  subgraph cluster_legend {
    label="Legend";
    labelloc="t";
    labeljust="l";
    fontsize=12;
    color="#2ca25f";
    style="rounded";
    margin=14;
    legend_anchor [shape=point, width=0.01, label="", style=invis];
    legend_hit [shape=box, style="filled", fillcolor="#2ca25f", color="#2ca25f", label="Green = hit/live path"];
    legend_miss [shape=box, style="filled", fillcolor="#de2d26", color="#de2d26", label="Red = cold/error path"];
    legend_hit -> legend_miss [style=invis];
  }
  Node0x2d72d090 -> legend_anchor [style=invis, weight=100, minlen=2, constraint=true, color="#2ca25f"];
  legend_anchor -> legend_hit [style=invis, weight=100, minlen=2, constraint=true];
}
